cc_library {
    name: "libtinyalsa_mocha",
    host_supported: true,
    vendor_available: true,
    srcs: [
        "src/mixer.c",
        "src/pcm.c",
    ],
    cflags: ["-Werror", "-Wno-macro-redefined"],
    export_include_dirs: ["include"],
    local_include_dirs: ["include"],

    target: {
        darwin: {
            enabled: false,
        },
    },
}
