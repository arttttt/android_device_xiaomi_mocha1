cc_library_shared {
    name: "libw",
    multilib: {
        lib32: {
            srcs: ["intrinsics_shim.s"],
        },
        lib64: {
            srcs: ["intrinsics_shim.cpp"],
        },
    },
    shared_libs: ["libcutils"],
    vendor: true,
    recovery_available: true,
    arch: {
        arm: {
            version_script: "intrinsics_shim.arm.map",
        },
    },
}
